{
    "name": "phpthis/skeleton",
    "description": "A checked, minimal PHPThis application starting point.",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/balgf/PHPThis.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "phpthis/framework": "dev-main"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "profile": "phpthis check",
        "test": "php tests/run.php",
        "check": [
            "@profile",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": false,
        "sort-packages": true
    }
}
